# Project Status System Configuration - For my own recall bruhhh

# Admin Authentication
# Set a strong password for admin dashboard access
# cmd i found :
# -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
ADMIN_PASSWORD=my-admin-password-here 

# API Key for securing manual status updates (optional but recommended)
# Generate a strong random key: openssl rand -hex 32 terminal is best duhh 
# cmd i found :
# -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) }) 
PROJECT_STATUS_API_KEY=my-secure-api-key-here

# Notification Webhooks (feature)
# Get Slack webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=slack's webhook url - dashboard 
# Get Discord webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=discord's webhook url - aleart channel settled up currently

# Site URL for automated checks (used by scripts/check-project-status.js)
SITE_URL=https://xyz.com

# Email Configuration (if using nodemailer for existing contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=x@gmail.com
EMAIL_PASSWORD=x
